# CMDB-Kit Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored and will not be committed.
# Environment variables set in your shell override values in this file.

# --------------------------------------------------------------------------
# JSM Connection
# --------------------------------------------------------------------------

# Cloud: your Atlassian site URL (e.g. https://yoursite.atlassian.net)
# Data Center: your JSM server URL (e.g. http://your-jsm:8080)
JSM_URL=https://yoursite.atlassian.net

# Cloud: your Atlassian email address
# Data Center: your JSM admin username
JSM_USER=you@example.com

# Cloud: API token from https://id.atlassian.com/manage-profile/security/api-tokens
# Data Center: your JSM admin password
JSM_PASSWORD=your-api-token

# --------------------------------------------------------------------------
# Schema Target
# --------------------------------------------------------------------------

# Object schema key in JSM (must match exactly, case-sensitive)
SCHEMA_KEY=CMDB

# Schema layer to use: schema/base, schema/extended, or schema/enterprise
SCHEMA_DIR=schema/base

# Data directory (defaults to SCHEMA_DIR/data)
DATA_DIR=schema/base/data

# --------------------------------------------------------------------------
# Optional
# --------------------------------------------------------------------------

# Cloud only: workspace ID (auto-detected if not set)
# JSM_WORKSPACE_ID=

# Set to true to create the schema if it does not exist
# CREATE_SCHEMA=false

# Set to true for HTTP debug logging
# DEBUG=false
